# ============================================================
# Semantic Search System — Environment Variables
# Copy to .env and adjust as needed.
# ============================================================

# Semantic cache similarity threshold (0.0–1.0)
# 0.85 = balanced default; lower = more hits; higher = stricter matching
SIMILARITY_THRESHOLD=0.85

# Number of vector DB results to return per query
TOP_K=10

# Set to 'true' to force re-indexing the dataset on next startup
# After first run, set back to 'false' for fast loading from disk
REBUILD_INDEX=false

# Limit corpus size for development (comment out or leave empty for full corpus)
# MAX_DOCS=500

# Override embedding model (must be a sentence-transformers compatible identifier)
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
